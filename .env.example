# =============================================================
# Keepsy MVP — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file with real secrets.
# =============================================================

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_USE_DALLE3=true

# ── Upstash Redis (rate limiting) ─────────────────────────────
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ── Resend (transactional email) ──────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Keepsy <hello@keepsy.store>

# ── Site URLs ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://keepsy.store
SITE_URL=https://keepsy.store

# ── Printify ──────────────────────────────────────────────────
PRINTIFY_API_TOKEN=...
PRINTIFY_SHOP_ID=...
PRINTIFY_WEBHOOK_SECRET=...

# ── Cloudinary (image hosting for generated designs) ──────────
# Configure via individual vars OR CLOUDINARY_URL (not both)
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ── Admin / Internal ──────────────────────────────────────────
MOCKUP_CALIBRATION_ENABLED=false
MOCKUP_CALIBRATION_KEY=...
PERF_DASHBOARD_KEY=...
